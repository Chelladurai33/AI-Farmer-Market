# Database - UPDATE THIS with your PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_farmer_db

# JWT Secrets - CHANGE THESE in production
JWT_ACCESS_SECRET=agroconnect_access_secret_key_change_in_production
JWT_REFRESH_SECRET=agroconnect_refresh_secret_key_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google Gemini AI - Required for AI features
GEMINI_API_KEY=your_gemini_api_key_here

# Cloudinary - Required for image uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# OpenWeather - Required for weather dashboard (or use mock data)
OPENWEATHER_API_KEY=Your_key

# Google Maps - Required for maps in cold storage
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# App
CLIENT_URL=http://localhost:5173
PORT=5000
NODE_ENV=development
