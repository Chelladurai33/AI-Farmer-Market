# ─── Database ────────────────────────────────────────────────────────────────
# Render PostgreSQL: copy the "Internal Database URL" from your Render DB dashboard
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/ai_farmer_db

# ─── JWT Secrets ──────────────────────────────────────────────────────────────
# IMPORTANT: Use long random strings in production (32+ chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_USE_LONG_RANDOM_STRING_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_USE_DIFFERENT_LONG_RANDOM_STRING_64_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# Required for: chatbot, disease detection, price prediction, demand forecast
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Required for: product images, avatars, disease detection uploads
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── OpenWeather ──────────────────────────────────────────────────────────────
# Required for: weather dashboard (falls back to mock data if not set)
# Get from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key

# ─── Google Maps ──────────────────────────────────────────────────────────────
# Required for: cold storage map view
# Get from: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─── App Configuration ────────────────────────────────────────────────────────
# In production: set to your Render frontend URL (e.g. https://ai-farmer-market.onrender.com)
# Multiple origins supported, comma-separated: https://app1.com,https://app2.com
CLIENT_URL=http://localhost:5173
PORT=5000
NODE_ENV=development

# ─── Logging ──────────────────────────────────────────────────────────────────
# Optional: debug, info, warn, error (defaults to 'info' in production, 'debug' in dev)
LOG_LEVEL=info
